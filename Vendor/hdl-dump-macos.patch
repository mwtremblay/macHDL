+    if (result == RET_OK) { /* accept the input, only if it is a block or character (raw) device */
 #if !defined(_DEBUG)        /* in debug mode treat files as devices */
-        result = st.st_mode & S_IFBLK ? RET_OK : RET_BAD_DEVICE;
