diff --git a/osal_unix.c b/osal_unix.c
index 1298b9f..eb9e77f 100644
--- a/osal_unix.c
+++ b/osal_unix.c
@@ -95,11 +95,38 @@ int /* OSAL_OK, OSAL_ERR */
 osal_open_device_for_writing(const char *device_name,
                              osal_handle_t *handle)
 {
-    handle->desc = open(device_name, O_RDWR | O_LARGEFILE | O_DSYNC, S_IRUSR | S_IWUSR);
+    /* mac-hdl-gui: deliberately no O_DSYNC here (removed) -- forcing every
+     * ~1MB write to synchronously complete on the physical device made bulk
+     * installs extremely slow over USB, especially to a spinning drive.
+     * Writes are now buffered/pipelined by the OS for speed; durability is
+     * instead guaranteed by an explicit osal_sync() call at the one point
+     * that actually matters -- right after the partition table is committed
+     * (see apa_commit_ex's caller in hdl.c's inject_data, and apa_commit's
+     * existing hio->flush call, both of which now do a real flush via
+     * win32_flush -> osal_sync on Unix). A single sync there commits
+     * everything written on this handle up to that point (bulk data +
+     * partition header + TOC), which is the same safety property O_DSYNC
+     * provided, just paid for once instead of once per chunk. */
+    handle->desc = open(device_name, O_RDWR | O_LARGEFILE, S_IRUSR | S_IWUSR);
     return (handle->desc == -1 ? OSAL_ERR : OSAL_OK);
 }
 
 
+/**************************************************************/
+int /* OSAL_OK, OSAL_ERR */
+osal_sync(osal_handle_t handle)
+{
+#if defined(__APPLE__)
+    /* fsync() on macOS only guarantees data reached the drive's write
+     * cache, not physical media -- F_FULLFSYNC is Apple's documented way to
+     * get a true durability barrier, which is the property we need here. */
+    return (fcntl(handle.desc, F_FULLFSYNC) == -1 ? OSAL_ERR : OSAL_OK);
+#else
+    return (fsync(handle.desc) == -1 ? OSAL_ERR : OSAL_OK);
+#endif
+}
+
+
