diff --git a/hio_win32.c b/hio_win32.c
index e3514fb..e091db0 100644
--- a/hio_win32.c
+++ b/hio_win32.c
@@ -97,9 +97,20 @@ win32_write(hio_t *hio,
 
 /**************************************************************/
 static int
-win32_flush(/*@unused@*/ hio_t *hio)
-{ /* win32_flush is intentionately blank */
+win32_flush(hio_t *hio)
+{
+#if defined(_BUILD_UNIX)
+    /* mac-hdl-gui: osal_open_device_for_writing no longer opens with
+     * O_DSYNC (see its comment) -- this is now the real durability barrier,
+     * called right after the partition table is committed (apa_commit's
+     * existing hio->flush call, and the added one in hdl.c's inject_data). */
+    hio_win32_t *hw32 = (hio_win32_t *)hio;
+    return (osal_sync(hw32->device) == OSAL_OK ? RET_OK : RET_ERR);
+#else
+    /* win32_flush is intentionately blank on Windows -- unchanged */
+    (void)hio;
     return (RET_OK);
+#endif
 }
 
 
diff --git a/iin.h b/iin.h
index dc7f712..1eab853 100644
--- a/iin.h
+++ b/iin.h
@@ -31,7 +31,17 @@
 C_START
 
 #define IIN_SECTOR_SIZE 2048u /* CD/DVD sector size */
-#define IIN_NUM_SECTORS 512u  /* number of sectors to read at once */
+/* mac-hdl-gui: bumped from 512 (1MB chunks) to 4096 (8MB chunks). Cheap
+ * USB-SATA bridge chipsets (common in PS2 HDD enclosures) often use
+ * Bulk-Only Transport rather than UASP, which has no command pipelining --
+ * each I/O op pays a fixed per-command round-trip cost regardless of size,
+ * so small chunks bottleneck throughput far below what the drive/bus can
+ * actually do. Larger chunks amortize that fixed cost over more bytes.
+ * Confirmed safe for this build: every consumer of this constant that's
+ * actually compiled here (USE_THREADED_IIN=no excludes thd_iin.c, the Unix
+ * build excludes iin_spti.c/iin_aspi.c) allocates its buffer on the heap via
+ * osal_alloc/al_alloc, not the stack, so this doesn't risk a stack overflow. */
+#define IIN_NUM_SECTORS 4096u /* number of sectors to read at once */
 
 
